<?php
require_once __DIR__ . '/../Model/Book.php';
require_once __DIR__ . '/../config.php';

class BookController {

    // Display a single book (var_dump + show())
    public function showBook(Book $book) {
        echo "<h3>Informations du livre :</h3>";
        var_dump($book);
        echo "<table border='1'>";
        echo "<tr><th>ID</th><th>Titre</th><th>Auteur</th><th>Date</th><th>Langue</th><th>Statut</th><th>Exemplaires</th><th>Catégorie</th></tr>";
        echo $book->show();
        echo "</table>";
    }

    // List all books from DB
    public function listBooks() {
        $pdo = Config::getConnexion();
        $stmt = $pdo->query("SELECT * FROM Book");
        $books = [];
        while ($row = $stmt->fetch()) {
            $book = new Book(
                $row['id'], $row['title'], $row['author'], $row['publication_date'],
                $row['language'], $row['status'], $row['copies'], $row['category']
            );
            $books[] = $book;
        }
        return $books;
    }

    // Add a new book
    public function addBook(Book $book) {
        $pdo = Config::getConnexion();
        $sql = "INSERT INTO Book (title, author, publication_date, language, status, copies, category)
                VALUES (:title, :author, :pub_date, :lang, :status, :copies, :category)";
        $stmt = $pdo->prepare($sql);
        $stmt->execute([
            ':title' => $book->getTitle(),
            ':author' => $book->getAuthor(),
            ':pub_date' => $book->getPublicationDate(),
            ':lang' => $book->getLanguage(),
            ':status' => $book->getStatus(),
            ':copies' => $book->getCopies(),
            ':category' => $book->getCategory()
        ]);
        return $pdo->lastInsertId();
    }

    // Delete a book by ID
    public function deleteBook($id) {
        $pdo = Config::getConnexion();
        $stmt = $pdo->prepare("DELETE FROM Book WHERE id = :id");
        $stmt->execute([':id' => $id]);
    }

    // Get a book by ID (for update form)
    public function getBookById($id) {
        $pdo = Config::getConnexion();
        $stmt = $pdo->prepare("SELECT * FROM Book WHERE id = :id");
        $stmt->execute([':id' => $id]);
        $row = $stmt->fetch();
        if ($row) {
            return new Book(
                $row['id'], $row['title'], $row['author'], $row['publication_date'],
                $row['language'], $row['status'], $row['copies'], $row['category']
            );
        }
        return null;
    }

    // Update a book
    public function updateBook(Book $book) {
        $pdo = Config::getConnexion();
        $sql = "UPDATE Book SET title = :title, author = :author, publication_date = :pub_date,
                language = :lang, status = :status, copies = :copies, category = :category
                WHERE id = :id";
        $stmt = $pdo->prepare($sql);
        $stmt->execute([
            ':id' => $book->getId(),
            ':title' => $book->getTitle(),
            ':author' => $book->getAuthor(),
            ':pub_date' => $book->getPublicationDate(),
            ':lang' => $book->getLanguage(),
            ':status' => $book->getStatus(),
            ':copies' => $book->getCopies(),
            ':category' => $book->getCategory()
        ]);
    }
}
?>